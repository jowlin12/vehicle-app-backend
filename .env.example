SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Credenciales OAuth exclusivas del backend. Nunca se incluyen en Flutter.
GOOGLE_DRIVE_CLIENT_ID=your-google-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-google-client-secret
GOOGLE_DRIVE_REFRESH_TOKEN=your-google-refresh-token
# Carpeta PADRE que contendrá una carpeta por placa (no colocar aquí el ID de una placa).
GOOGLE_DRIVE_VEHICLE_FOLDER_ID=your-vehicle-root-folder-id
GOOGLE_DRIVE_INVOICE_FOLDER_ID=your-invoice-root-folder-id

# Separar varios orígenes web con comas. Las apps Android/iOS no envían Origin.
ALLOWED_ORIGINS=https://your-flutter-web.example.com
